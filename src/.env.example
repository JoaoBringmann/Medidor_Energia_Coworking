# Configurações do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_NAME=seu_banco_de_dados

# Configurações do InfluxDB
INFLUX_HOST=localhost
INFLUX_PORT=8086
INFLUX_DB=nome_do_banco_influx

# Configurações de Segurança (JWT)
SECRET_KEY=insira_uma_chave_aleatoria_aqui
ALGORITHM=HS256

INITIAL_ADMIN_PASSWORD=defina_uma_senha_para_o_admin_aqui